{
  "extraKnownMarketplaces": {
    "unicli": {
      "source": {
        "source": "github",
        "repo": "yucchiy/UniCli"
      }
    }
  },
  "enabledPlugins": {
    "unicli@unicli": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/rebuild-generators-on-change.sh\""
          }
        ]
      }
    ]
  }
}
