<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" editor-extension-mode="True">
    <!-- Static skeleton for TypeSelectorView. The dynamic parts (breadcrumb trail, list rows, keyboard) are wired in
         code; this declares only the fixed shell. Child order here matches the order the view used to build by hand:
         header, error, list, empty-hint, footer-hint. Runtime-toggled classes/styles stay in code. -->
    <ui:VisualElement name="type-selector-header" class="aspid-fasttools-type-selector__header">
        <ui:Button name="type-selector-search-button" tooltip="Search types" class="aspid-fasttools-type-selector__search-button unity-search-field-base__search-button"/>
        <ui:VisualElement name="type-selector-breadcrumb-bar" class="aspid-fasttools-type-selector__trail"/>
        <uie:ToolbarSearchField name="type-selector-search-field" class="aspid-fasttools-type-selector__search-field"/>
    </ui:VisualElement>
    <ui:Label name="type-selector-error" class="aspid-fasttools-type-selector__error" style="display: none;"/>
    <ui:ListView name="type-selector-list" selection-type="Single" virtualization-method="DynamicHeight"/>
    <ui:Label name="type-selector-empty-hint" class="aspid-fasttools-type-selector__empty-hint" style="display: none;"/>
    <ui:Label name="type-selector-footer-hint" picking-mode="Ignore" class="aspid-fasttools-type-selector__footer-hint"/>
</ui:UXML>
